{
  "framework": null,
  "installCommand": "bash ./tools/vercel-build.sh --install-only && cd apps/node_backend && npm ci --omit=dev",
  "buildCommand": "bash ./tools/vercel-build.sh",
  "outputDirectory": "apps/mobile_chat_app/build/web",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/docs",
      "destination": "/docs/index.html"
    },
    {
      "source": "/docs/:path*",
      "destination": "/docs/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
