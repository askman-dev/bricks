# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/bricks

# Security
# Generate a secure random string for JWT_SECRET (at least 32 characters)
JWT_SECRET=your-jwt-secret-here-change-this-in-production

# Generate a secure random string for ENCRYPTION_KEY (at least 32 characters)
ENCRYPTION_KEY=your-encryption-key-here-change-this-in-production

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# CORS Configuration
# Set to your frontend URL in production (e.g., https://app.bricks.dev)
CORS_ORIGIN=*

# Database Migration
# Set to false to disable automatic migrations on server start
AUTO_MIGRATE=true
