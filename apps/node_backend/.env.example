# =============================================================================
# Backend-only secrets — must never be exposed to the Flutter Web client bundle
# Set these in the Vercel dashboard under Environment Variables (not committed)
# =============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/bricks

# Security — generate secure random strings (at least 32 characters each)
JWT_SECRET=your-jwt-secret-here-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-this-in-production

# GitHub OAuth — GITHUB_CLIENT_SECRET must remain server-side only
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitHub OAuth callback URL
# Local dev:  http://localhost:3000/api/auth/github/callback
# Production: https://bricks.askman.dev/api/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# CORS — set to your frontend origin in production (e.g., https://bricks.askman.dev)
CORS_ORIGIN=*

# Database Migration
# Set to false to disable automatic migrations on server start
# In production, run migrations manually via: npm run migrate
AUTO_MIGRATE=true

# =============================================================================
# Frontend-safe public configuration
# GITHUB_CLIENT_ID is the public OAuth app identifier (not a secret)
# =============================================================================

GITHUB_CLIENT_ID=your-github-client-id
